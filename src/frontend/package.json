{
  "name": "@fullstack-template/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "architecture:check": "python3 ../../scripts/check_frontend_architecture.py",
    "api:generate": "uv run --project ../backend python ../../scripts/generate_frontend_openapi_client.py",
    "api:check": "uv run --project ../backend python ../../scripts/generate_frontend_openapi_client.py --check",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^2.1.0",
    "@opentelemetry/core": "^2.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/instrumentation": "^0.205.0",
    "@opentelemetry/instrumentation-document-load": "^0.59.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-web": "^2.1.0",
    "@sentry/vue": "^10.21.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.23.0",
    "eslint-plugin-vue": "^10.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^5.4.18",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^3.2.6"
  }
}
