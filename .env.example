REGISTRIES_APP__NAME=Registries API
REGISTRIES_APP__VERSION=0.1.0
REGISTRIES_APP__ENVIRONMENT=local
REGISTRIES_API__HOST=0.0.0.0
REGISTRIES_API__PORT=8000
REGISTRIES_API__PREFIX=/api
REGISTRIES_DB__POSTGRES_DSN=postgresql+asyncpg://registries:registries@localhost:5432/registries
REGISTRIES_DB__REDIS_URL=redis://localhost:6379/0
REGISTRIES_BROKER__TASKIQ_QUEUE_NAME=registries:taskiq
REGISTRIES_BROKER__TASKIQ_CONSUMER_GROUP_NAME=registries:backend
REGISTRIES_OBSERVABILITY__ENABLED=true
REGISTRIES_OBSERVABILITY__LOGS_ENABLED=true
REGISTRIES_OBSERVABILITY__LOG_LEVEL=INFO
REGISTRIES_OBSERVABILITY__TRACES_ENABLED=false
REGISTRIES_OBSERVABILITY__OTLP_ENDPOINT=
REGISTRIES_OBSERVABILITY__OTLP_HEADERS=
REGISTRIES_OBSERVABILITY__METRICS_ENABLED=true
REGISTRIES_OBSERVABILITY__METRICS_PATH=/metrics
REGISTRIES_OBSERVABILITY__REQUEST_ID_HEADER=X-Request-ID
REGISTRIES_OBSERVABILITY__CORRELATION_ID_HEADER=X-Correlation-ID
REGISTRIES_OBSERVABILITY__SENTRY_ENABLED=false
REGISTRIES_OBSERVABILITY__GLITCHTIP_DSN=
REGISTRIES_OBSERVABILITY__TRACE_SAMPLE_RATE=0.1
REGISTRIES_OBSERVABILITY__PROFILE_SAMPLE_RATE=0.0
REGISTRIES_OBSERVABILITY__INSTRUMENT_SQLALCHEMY=true
REGISTRIES_OBSERVABILITY__INSTRUMENT_REDIS=true
REGISTRIES_OBSERVABILITY__INSTRUMENT_HTTPX=false
RUN_DB_MIGRATIONS=true
