FULLSTACK_TEMPLATE_APP__NAME=Fullstack Template API
FULLSTACK_TEMPLATE_APP__VERSION=0.1.0
FULLSTACK_TEMPLATE_APP__ENVIRONMENT=local
FULLSTACK_TEMPLATE_API__HOST=0.0.0.0
FULLSTACK_TEMPLATE_API__PORT=8000
FULLSTACK_TEMPLATE_API__PREFIX=/api
FULLSTACK_TEMPLATE_DB__POSTGRES_DSN=postgresql+asyncpg://fullstack_template:fullstack_template@localhost:5432/fullstack_template
FULLSTACK_TEMPLATE_DB__REDIS_URL=redis://localhost:6379/0
FULLSTACK_TEMPLATE_BROKER__TASKIQ_QUEUE_NAME=fullstack-template:taskiq
FULLSTACK_TEMPLATE_BROKER__TASKIQ_CONSUMER_GROUP_NAME=fullstack-template:backend
FULLSTACK_TEMPLATE_OBSERVABILITY__ENABLED=true
FULLSTACK_TEMPLATE_OBSERVABILITY__LOGS_ENABLED=true
FULLSTACK_TEMPLATE_OBSERVABILITY__LOG_LEVEL=INFO
FULLSTACK_TEMPLATE_OBSERVABILITY__TRACES_ENABLED=false
FULLSTACK_TEMPLATE_OBSERVABILITY__OTLP_ENDPOINT=
FULLSTACK_TEMPLATE_OBSERVABILITY__OTLP_HEADERS=
FULLSTACK_TEMPLATE_OBSERVABILITY__METRICS_ENABLED=true
FULLSTACK_TEMPLATE_OBSERVABILITY__METRICS_PATH=/metrics
FULLSTACK_TEMPLATE_OBSERVABILITY__REQUEST_ID_HEADER=X-Request-ID
FULLSTACK_TEMPLATE_OBSERVABILITY__CORRELATION_ID_HEADER=X-Correlation-ID
FULLSTACK_TEMPLATE_OBSERVABILITY__SENTRY_ENABLED=false
FULLSTACK_TEMPLATE_OBSERVABILITY__GLITCHTIP_DSN=
FULLSTACK_TEMPLATE_OBSERVABILITY__TRACE_SAMPLE_RATE=0.1
FULLSTACK_TEMPLATE_OBSERVABILITY__PROFILE_SAMPLE_RATE=0.0
FULLSTACK_TEMPLATE_OBSERVABILITY__INSTRUMENT_SQLALCHEMY=true
FULLSTACK_TEMPLATE_OBSERVABILITY__INSTRUMENT_REDIS=true
FULLSTACK_TEMPLATE_OBSERVABILITY__INSTRUMENT_HTTPX=false
RUN_DB_MIGRATIONS=true
